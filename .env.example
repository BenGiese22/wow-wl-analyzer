# Warcraft Logs API credentials
# Create a client at: https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here

# Report to analyze (the code from your WCL report URL)
# e.g., https://www.warcraftlogs.com/reports/aAbBcCdDeE -> code is aAbBcCdDeE
WCL_REPORT_CODE=your_report_code_here

# Comparison settings
TARGET_REGION=US
TARGET_KEYSTONE_LEVEL=18
TOP_N_PARSES=10
